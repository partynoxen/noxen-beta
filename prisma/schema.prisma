generator client {
    provider = "prisma-client-js"
    binaryTargets = ["native", "linux-musl-arm64-openssl-3.0.x"]
    output = "/home/ubuntu/vybe/nextjs_space/node_modules/.prisma/client"
}

datasource db {
    provider = "postgresql"
    url      = env("DATABASE_URL")
}

model User {
  id         String   @id @default(uuid())
  name       String
  email      String   @unique
  avatarUrl  String?  @map("avatar_url")
  createdAt  DateTime @default(now()) @map("created_at")

  savedEvents  UserSavedEvent[]
  likedEvents  UserLikedEvent[]
  vibeUploads  VibeUpload[]

  @@map("users")
}

model Event {
  id          String   @id @default(uuid())
  title       String
  clubName    String   @map("club_name")
  city        String
  location    String
  lat         Decimal? @db.Decimal(10, 7)
  lng         Decimal? @db.Decimal(10, 7)
  genre       String
  date        DateTime @db.Date
  startTime   String   @map("start_time")
  endTime     String   @map("end_time")
  price       Decimal  @db.Decimal(10, 2)
  ticketUrl   String?  @map("ticket_url")
  mediaUrl    String?  @map("media_url")
  description String
  lineup      String?
  views       Int      @default(0)
  likes       Int      @default(0)
  saves       Int      @default(0)
  checkins    Int      @default(0)
  heatScore   Int      @default(0) @map("heat_score")
  createdAt   DateTime @default(now()) @map("created_at")

  savedBy      UserSavedEvent[]
  likedBy      UserLikedEvent[]
  vibeUploads  VibeUpload[]

  @@index([city])
  @@index([genre])
  @@index([date])
  @@index([heatScore])
  @@map("events")
}

model UserSavedEvent {
  id        String   @id @default(uuid())
  userId    String   @map("user_id")
  eventId   String   @map("event_id")
  createdAt DateTime @default(now()) @map("created_at")

  user  User  @relation(fields: [userId], references: [id])
  event Event @relation(fields: [eventId], references: [id])

  @@unique([userId, eventId])
  @@map("user_saved_events")
}

model UserLikedEvent {
  id        String   @id @default(uuid())
  userId    String   @map("user_id")
  eventId   String   @map("event_id")
  createdAt DateTime @default(now()) @map("created_at")

  user  User  @relation(fields: [userId], references: [id])
  event Event @relation(fields: [eventId], references: [id])

  @@unique([userId, eventId])
  @@map("user_liked_events")
}

model VibeUpload {
  id             String   @id @default(uuid())
  userId         String   @map("user_id")
  eventId        String   @map("event_id")
  cloudStoragePath String? @map("cloud_storage_path")
  isPublic       Boolean  @default(true) @map("is_public")
  caption        String?
  rating         Int
  createdAt      DateTime @default(now()) @map("created_at")

  user  User  @relation(fields: [userId], references: [id])
  event Event @relation(fields: [eventId], references: [id])

  @@map("vibe_uploads")
}
